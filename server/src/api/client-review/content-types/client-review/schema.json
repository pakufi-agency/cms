{
  "kind": "collectionType",
  "collectionName": "client_reviews",
  "info": {
    "singularName": "client-review",
    "pluralName": "client-reviews",
    "displayName": "ClientReview",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "reviewTitle": {
      "type": "string",
      "required": true
    },
    "reviewContent": {
      "type": "text",
      "required": true
    },
    "location": {
      "type": "string",
      "required": false
    },
    "company": {
      "type": "string"
    },
    "companyUrl": {
      "type": "string"
    },
    "rating": {
      "type": "integer",
      "required": true,
      "max": 5
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    }
  }
}
